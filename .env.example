LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434

EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16

KNOWLEDGE_DIR=knowledge
CHROMA_PERSIST_DIR=storage/chroma
OUTPUT_DIR=output
HF_HOME=
SENTENCE_TRANSFORMERS_HOME=
CHROMA_COLLECTION=greenloop_documents

# Azure runtime configuration. Set LLM_PROVIDER=azure to enable these values.
AZURE_LLM_MODEL=azure/<deployment-or-model-name>
AZURE_API_KEY=
AZURE_ENDPOINT=
AZURE_API_VERSION=
